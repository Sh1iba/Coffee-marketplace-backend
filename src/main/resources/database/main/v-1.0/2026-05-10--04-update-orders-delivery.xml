<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="2026-05-10--04-orders-add-branch" author="zafar">
        <addColumn tableName="orders">
            <column name="branch_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="2026-05-10--04-orders-add-courier" author="zafar">
        <addColumn tableName="orders">
            <column name="courier_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="2026-05-10--04-orders-add-delivery-type" author="zafar">
        <addColumn tableName="orders">
            <column name="delivery_type" type="VARCHAR(15)" defaultValue="DELIVERY">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="2026-05-10--04-orders-delivery-address-nullable" author="zafar">
        <dropNotNullConstraint tableName="orders" columnName="delivery_address" columnDataType="VARCHAR(500)"/>
    </changeSet>

    <changeSet id="2026-05-10--04-orders-status-column-widen" author="zafar">
        <modifyDataType tableName="orders" columnName="status" newDataType="VARCHAR(25)"/>
    </changeSet>

</databaseChangeLog>
